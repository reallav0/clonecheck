{
  "name": "clonecheck",
  "version": "0.1.0",
  "description": "Know if your repo is actually cloneable.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reallav0/clonecheck.git",
    "directory": "packages/npm"
  },
  "bugs": {
    "url": "https://github.com/reallav0/clonecheck/issues"
  },
  "homepage": "https://github.com/reallav0/clonecheck#readme",
  "keywords": [
    "clonecheck",
    "cli",
    "npx",
    "developer-experience",
    "repository",
    "readme"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "clonecheck": "./dist/index.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "node ../../scripts/build-package.mjs .",
    "dev": "tsx src/index.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "scan": "tsx src/index.ts scan",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@clonecheck/cli": "workspace:*"
  }
}
