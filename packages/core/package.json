{
  "name": "@clonecheck/core",
  "version": "0.1.0",
  "description": "Core repository usability scanner for clonecheck.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reallav0/clonecheck.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/reallav0/clonecheck/issues"
  },
  "homepage": "https://github.com/reallav0/clonecheck#readme",
  "keywords": [
    "clonecheck",
    "developer-experience",
    "repository",
    "readme",
    "static-analysis"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "node ../../scripts/build-package.mjs .",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "fast-glob": "^3.3.3",
    "js-yaml": "^4.1.0",
    "picocolors": "^1.1.1",
    "zod": "^3.24.1"
  }
}
